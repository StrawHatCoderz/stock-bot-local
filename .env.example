# Required. docker-compose substitutes this into the chatapp service's
# ANTHROPIC_API_KEY env var (see docker-compose.yml) — the container reads
# it directly at runtime, it is not baked into the image.
ANTHROPIC_API_KEY=

# Optional. Caps how many services `docker-compose build`/`up` builds or
# pulls in parallel. Not read by any service — this is a docker-compose
# CLI-only setting, unset is fine on most machines. Worth setting to 1 on
# a small/low-memory box, since building the 3 Java services concurrently
# can otherwise exhaust it.
COMPOSE_PARALLEL_LIMIT=1
