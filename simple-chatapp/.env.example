# Claude Agent SDK credentials
ANTHROPIC_API_KEY=

# Base URL for the real Auth/Validation/Stock backend — the nginx gateway
# from services/docker-compose.yml by default. Used directly by
# POST /api/auth/login (server.ts), and passed through as API_BASE_URL to
# the mcp/ server subprocess (ai-client.ts).
STOCK_API_BASE_URL=http://localhost:8080

# Optional: chat server port (defaults to 3001 if unset)
PORT=3001
